<Window x:Class="GearBoardBridge.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings — GearBoard Bridge"
        Width="420" Height="560"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BgDarkBrush}">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Grid.Row="0" Text="Settings" Style="{StaticResource HeadingText}"
                   FontSize="18" Margin="0,0,0,16"/>

        <!-- Settings content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <!-- ── AUTO-CONNECT ── -->
                <Border Style="{StaticResource CardBorder}" Margin="0,0,0,8">
                    <StackPanel>
                        <TextBlock Text="AUTO-CONNECT" FontSize="10" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   Margin="0,0,0,10" Typography.Capitals="AllSmallCaps"/>

                        <Grid Margin="0,0,0,8">
                            <TextBlock Text="Auto-connect on startup" Style="{StaticResource BodyText}"
                                       VerticalAlignment="Center"/>
                            <CheckBox IsChecked="{Binding AutoConnectOnStartup}"
                                      HorizontalAlignment="Right" VerticalAlignment="Center"/>
                        </Grid>

                        <Grid>
                            <StackPanel>
                                <TextBlock Text="Last device" Style="{StaticResource SecondaryText}"/>
                                <TextBlock Text="{Binding LastDeviceSummary}"
                                           Style="{StaticResource BodyText}" Margin="0,2,0,0"
                                           Foreground="{StaticResource AccentAmberBrush}"/>
                            </StackPanel>
                            <Button Content="Clear" Style="{StaticResource SecondaryButton}"
                                    HorizontalAlignment="Right" VerticalAlignment="Center"
                                    Padding="10,4" FontSize="12"
                                    Command="{Binding ClearLastDeviceCommand}"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- ── TRANSPORT PRIORITY ── -->
                <Border Style="{StaticResource CardBorder}" Margin="0,0,0,8">
                    <StackPanel>
                        <TextBlock Text="TRANSPORT PRIORITY" FontSize="10" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   Margin="0,0,0,10" Typography.Capitals="AllSmallCaps"/>

                        <RadioButton Content="Auto  (USB → WiFi → BLE)" Margin="0,4"
                                     IsChecked="{Binding PriorityAuto}"
                                     Foreground="{StaticResource TextPrimaryBrush}"/>
                        <TextBlock Text="Best for studio — always picks the lowest-latency option."
                                   Style="{StaticResource SecondaryText}" Margin="20,0,0,8"/>

                        <RadioButton Content="WiFi first  (WiFi → USB → BLE)" Margin="0,4"
                                     IsChecked="{Binding PriorityWifi}"
                                     Foreground="{StaticResource TextPrimaryBrush}"/>
                        <TextBlock Text="Best for stage — stays wireless even when a USB cable is plugged in."
                                   Style="{StaticResource SecondaryText}" Margin="20,0,0,8"/>

                        <RadioButton Content="BLE first  (BLE → WiFi → USB)" Margin="0,4"
                                     IsChecked="{Binding PriorityBle}"
                                     Foreground="{StaticResource TextPrimaryBrush}"/>
                        <TextBlock Text="USB cable is for charging only — always use Bluetooth."
                                   Style="{StaticResource SecondaryText}" Margin="20,0,0,4"/>
                    </StackPanel>
                </Border>

                <!-- ── STARTUP ── -->
                <Border Style="{StaticResource CardBorder}" Margin="0,0,0,8">
                    <StackPanel>
                        <TextBlock Text="STARTUP" FontSize="10" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   Margin="0,0,0,10" Typography.Capitals="AllSmallCaps"/>

                        <Grid Margin="0,0,0,8">
                            <TextBlock Text="Start minimized to tray" Style="{StaticResource BodyText}"
                                       VerticalAlignment="Center"/>
                            <CheckBox IsChecked="{Binding StartMinimized}"
                                      HorizontalAlignment="Right" VerticalAlignment="Center"/>
                        </Grid>
                        <Grid>
                            <TextBlock Text="Launch with Windows" Style="{StaticResource BodyText}"
                                       VerticalAlignment="Center"/>
                            <CheckBox IsChecked="{Binding StartWithWindows}"
                                      HorizontalAlignment="Right" VerticalAlignment="Center"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- ── VIRTUAL MIDI PORT ── -->
                <Border Style="{StaticResource CardBorder}" Margin="0,0,0,8">
                    <StackPanel>
                        <TextBlock Text="VIRTUAL MIDI PORT" FontSize="10" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   Margin="0,0,0,10" Typography.Capitals="AllSmallCaps"/>

                        <TextBlock Text="Port name (shown in DAWs)" Style="{StaticResource SecondaryText}"
                                   Margin="0,0,0,4"/>
                        <TextBox Text="{Binding VirtualPortName, UpdateSourceTrigger=PropertyChanged}"
                                 Background="{StaticResource BgSurfaceHoverBrush}"
                                 Foreground="{StaticResource TextPrimaryBrush}"
                                 BorderBrush="{StaticResource BorderSubtleBrush}"
                                 Padding="8,6" FontSize="13"/>
                        <TextBlock Text="Requires restart to take effect."
                                   Style="{StaticResource SecondaryText}"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   Margin="0,4,0,0" FontSize="11"/>
                    </StackPanel>
                </Border>

                <!-- ── WIFI MIDI ── -->
                <Border Style="{StaticResource CardBorder}" Margin="0,0,0,8">
                    <StackPanel>
                        <TextBlock Text="WIFI MIDI" FontSize="10" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   Margin="0,0,0,10" Typography.Capitals="AllSmallCaps"/>

                        <TextBlock Text="UDP port" Style="{StaticResource SecondaryText}"
                                   Margin="0,0,0,4"/>
                        <TextBox Text="{Binding WifiPort, UpdateSourceTrigger=PropertyChanged}"
                                 Background="{StaticResource BgSurfaceHoverBrush}"
                                 Foreground="{StaticResource TextPrimaryBrush}"
                                 BorderBrush="{StaticResource BorderSubtleBrush}"
                                 Padding="8,6" FontSize="13" Width="100"
                                 HorizontalAlignment="Left"/>
                        <TextBlock Text="Default: 5004. Change only if another app uses this port."
                                   Style="{StaticResource SecondaryText}"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   Margin="0,4,0,0" FontSize="11"/>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- Save / Cancel buttons -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right"
                    Margin="0,16,0,0">
            <Button Content="Cancel" Style="{StaticResource SecondaryButton}"
                    Width="90" Margin="0,0,8,0"
                    Command="{Binding CancelCommand}"/>
            <Button Content="Save" Style="{StaticResource PrimaryButton}"
                    Width="90"
                    Command="{Binding SaveCommand}"/>
        </StackPanel>
    </Grid>

    <Window.Style>
        <Style TargetType="Window">
            <Setter Property="FontFamily" Value="Segoe UI"/>
        </Style>
    </Window.Style>
</Window>
