<Window x:Class="GearBoardBridge.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="GearBoard Bridge"
        Width="440" Height="720"
        MinWidth="380" MinHeight="500"
        ResizeMode="CanMinimize"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BgDarkBrush}">

    <Window.Resources>
        <Style x:Key="StatusDotStyle" TargetType="Ellipse">
            <Setter Property="Width" Value="10"/>
            <Setter Property="Height" Value="10"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style x:Key="DawBullet" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="{StaticResource AccentAmberBrush}"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style x:Key="DawName" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style x:Key="DawPath" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="HorizontalAlignment" Value="Right"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ═══ TITLE BAR ═══ -->
        <Border Grid.Row="0"  Background="{StaticResource BgSurfaceBrush}"
                BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="0,0,0,1"
                Padding="16,10">
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="🎸" FontSize="18" Margin="0,0,8,0" VerticalAlignment="Center"/>
                    <TextBlock Text="GearBoard Bridge" Style="{StaticResource HeadingText}"
                               VerticalAlignment="Center"/>
                </StackPanel>
                <TextBlock Text="v1.0" Style="{StaticResource SecondaryText}"
                           HorizontalAlignment="Right" VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- ═══ MAIN CONTENT ═══ -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="16,16,16,0">
            <StackPanel>

                <!-- ═══ STATUS CARD ═══ -->
                <Border Style="{StaticResource CardBorder}">
                    <StackPanel>

                        <!-- Header -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <TextBlock Text="📡" FontSize="14" Foreground="{StaticResource AccentAmberBrush}"
                                       Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Status" Style="{StaticResource HeadingText}"/>
                        </StackPanel>

                        <!-- Status row: dot + text -->
                        <StackPanel Orientation="Horizontal" Margin="0,4">
                            <Ellipse Style="{StaticResource StatusDotStyle}"
                                     Fill="{Binding StatusDotColor, Converter={StaticResource HexColorToBrush}}"/>
                            <TextBlock Text="{Binding StatusText, Mode=OneWay}"
                                       Style="{StaticResource BodyText}" VerticalAlignment="Center"/>
                        </StackPanel>

                        <!-- Transport pill + latency (only when connected) -->
                        <StackPanel Orientation="Horizontal" Margin="18,6,0,0"
                                    Visibility="{Binding ConnectedDeviceName, Converter={StaticResource NullToCollapsed}}">
                            <Border Background="{StaticResource BleStatusBgBrush}"
                                    CornerRadius="12" Padding="10,4" Margin="0,0,8,0">
                                <TextBlock Text="{Binding TransportBadge, Mode=OneWay}"
                                           FontSize="11" FontWeight="SemiBold" Foreground="White"/>
                            </Border>
                            <TextBlock Style="{StaticResource SecondaryText}" VerticalAlignment="Center">
                                <Run Text="•  ~"/>
                                <Run Text="{Binding LatencyMs, StringFormat='{}{0:F0}', Mode=OneWay}"/>
                                <Run Text="ms latency"/>
                            </TextBlock>
                        </StackPanel>

                        <!-- Virtual port row (only when connected) -->
                        <StackPanel Orientation="Horizontal" Margin="18,4,0,0"
                                    Visibility="{Binding ConnectedDeviceName, Converter={StaticResource NullToCollapsed}}">
                            <TextBlock Style="{StaticResource SecondaryText}">
                                🎵  Port: GearBoard MIDI ✅
                            </TextBlock>
                        </StackPanel>

                    </StackPanel>
                </Border>

                <!-- ═══ ERROR BANNERS ═══ -->

                <!-- Bluetooth disabled banner -->
                <Border Background="#3B1A1A" BorderBrush="#EF5350" BorderThickness="1"
                        CornerRadius="8" Padding="12,10" Margin="0,0,0,8"
                        Visibility="{Binding ShowBluetoothError, Converter={StaticResource BoolToVisibility}}">
                    <Grid>
                        <StackPanel>
                            <TextBlock Text="Bluetooth is disabled" FontSize="13" FontWeight="SemiBold"
                                       Foreground="#EF5350"/>
                            <TextBlock Text="Enable Bluetooth to connect via BLE."
                                       Style="{StaticResource SecondaryText}" Margin="0,2,0,6"/>
                            <Button Content="Open Bluetooth Settings" Style="{StaticResource SecondaryButton}"
                                    HorizontalAlignment="Left" Padding="10,4" FontSize="12"
                                    Command="{Binding OpenBluetoothSettingsCommand}"/>
                        </StackPanel>
                        <Button Content="✕" HorizontalAlignment="Right" VerticalAlignment="Top"
                                Background="Transparent" BorderThickness="0"
                                Foreground="{StaticResource TextMutedBrush}" FontSize="14" Padding="4"
                                Command="{Binding DismissBluetoothErrorCommand}"/>
                    </Grid>
                </Border>

                <!-- USB not in MIDI mode banner -->
                <Border Background="#1A1A2E" BorderBrush="#FFA726" BorderThickness="1"
                        CornerRadius="8" Padding="12,10" Margin="0,0,0,8"
                        Visibility="{Binding ShowUsbModeError, Converter={StaticResource BoolToVisibility}}">
                    <Grid>
                        <StackPanel>
                            <TextBlock Text="USB device not in MIDI mode" FontSize="13" FontWeight="SemiBold"
                                       Foreground="#FFA726"/>
                            <TextBlock TextWrapping="Wrap" Style="{StaticResource SecondaryText}" Margin="0,2,0,0" LineHeight="18">
                                On your Android phone:&#x0a;1. Connect USB cable&#x0a;2. Pull down notification shade&#x0a;3. Tap "USB for charging" → select "MIDI"
                            </TextBlock>
                        </StackPanel>
                        <Button Content="✕" HorizontalAlignment="Right" VerticalAlignment="Top"
                                Background="Transparent" BorderThickness="0"
                                Foreground="{StaticResource TextMutedBrush}" FontSize="14" Padding="4"
                                Command="{Binding DismissUsbErrorCommand}"/>
                    </Grid>
                </Border>

                <!-- WiFi network mismatch banner -->
                <Border Background="#1A1A2E" BorderBrush="#42A5F5" BorderThickness="1"
                        CornerRadius="8" Padding="12,10" Margin="0,0,0,8"
                        Visibility="{Binding ShowWifiError, Converter={StaticResource BoolToVisibility}}">
                    <Grid>
                        <StackPanel>
                            <TextBlock Text="WiFi connection failed" FontSize="13" FontWeight="SemiBold"
                                       Foreground="#42A5F5"/>
                            <TextBlock TextWrapping="Wrap" Style="{StaticResource SecondaryText}" Margin="0,2,0,6" LineHeight="18">
                                Make sure both devices are on the same Wi-Fi network and GearBoard WiFi MIDI is enabled.
                            </TextBlock>
                            <Button Content="Open WiFi Settings" Style="{StaticResource SecondaryButton}"
                                    HorizontalAlignment="Left" Padding="10,4" FontSize="12"
                                    Command="{Binding OpenWifiSettingsCommand}"/>
                        </StackPanel>
                        <Button Content="✕" HorizontalAlignment="Right" VerticalAlignment="Top"
                                Background="Transparent" BorderThickness="0"
                                Foreground="{StaticResource TextMutedBrush}" FontSize="14" Padding="4"
                                Command="{Binding DismissWifiErrorCommand}"/>
                    </Grid>
                </Border>

                <!-- Generic error message -->
                <Border Background="#2A1A1A" CornerRadius="6" Padding="12,8" Margin="0,0,0,8"
                        Visibility="{Binding ErrorMessage, Converter={StaticResource NullToCollapsed}}">
                    <TextBlock Text="{Binding ErrorMessage}" Style="{StaticResource SecondaryText}"
                               Foreground="#EF5350" TextWrapping="Wrap"/>
                </Border>

                <!-- ═══ DEVICES CARD ═══ -->
                <Border Style="{StaticResource CardBorder}">
                    <StackPanel>

                        <!-- Header -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <TextBlock Text="🔍" FontSize="14" Foreground="{StaticResource AccentAmberBrush}"
                                       Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Devices" Style="{StaticResource HeadingText}"/>
                        </StackPanel>

                        <!-- Scan button -->
                        <Button Style="{StaticResource PrimaryButton}"
                                Command="{Binding StartScanCommand}"
                                HorizontalAlignment="Stretch" Margin="0,0,0,8">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <TextBlock Text="{Binding IsScanning, Converter={StaticResource ScanButtonText}}"
                                           Margin="0,0,0,0"/>
                            </StackPanel>
                        </Button>

                        <!-- Transport pills: color = active green if connected via that transport, else neutral -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <Border CornerRadius="12" Padding="10,4" Margin="0,0,8,0"
                                    Background="{Binding UsbPillColor, Converter={StaticResource HexColorToBrush}}">
                                <TextBlock Text="🔌 USB" FontSize="11" Foreground="White" FontWeight="SemiBold"/>
                            </Border>
                            <Border CornerRadius="12" Padding="10,4" Margin="0,0,8,0"
                                    Background="{Binding WifiPillColor, Converter={StaticResource HexColorToBrush}}">
                                <TextBlock Text="📶 WiFi" FontSize="11" Foreground="White" FontWeight="SemiBold"/>
                            </Border>
                            <Border CornerRadius="12" Padding="10,4"
                                    Background="{Binding BlePillColor, Converter={StaticResource HexColorToBrush}}">
                                <TextBlock Text="📡 BLE" FontSize="11" Foreground="White" FontWeight="SemiBold"/>
                            </Border>
                        </StackPanel>

                        <!-- Device list -->
                        <ItemsControl ItemsSource="{Binding DiscoveredDevices}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{StaticResource BgSurfaceHoverBrush}"
                                            CornerRadius="6" Padding="12,10" Margin="0,2"
                                            MinHeight="48">
                                        <Grid>
                                            <!-- Left: name + subtitle -->
                                            <StackPanel VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Name}"
                                                           FontSize="13" FontWeight="Medium"
                                                           Foreground="{StaticResource TextPrimaryBrush}"/>
                                                <TextBlock Text="{Binding SubtitleText}"
                                                           FontSize="11"
                                                           Foreground="{StaticResource TextSecondaryBrush}"
                                                           Margin="0,2,0,0"/>
                                            </StackPanel>

                                            <!-- "● Connected" badge — shown when this device IS connected -->
                                            <Border HorizontalAlignment="Right" VerticalAlignment="Center"
                                                    Background="{StaticResource ConnectedBgBrush}"
                                                    CornerRadius="6" Padding="12,5">
                                                <Border.Visibility>
                                                    <MultiBinding Converter="{StaticResource StringEqToVis}">
                                                        <Binding Path="Name"/>
                                                        <Binding Path="DataContext.ConnectedDeviceName"
                                                                 RelativeSource="{RelativeSource AncestorType=Window}"/>
                                                    </MultiBinding>
                                                </Border.Visibility>
                                                <TextBlock Text="● Connected"
                                                           FontSize="11" FontWeight="SemiBold"
                                                           Foreground="{StaticResource SuccessBrush}"/>
                                            </Border>

                                            <!-- Connect button — shown when this device is NOT connected -->
                                            <Button Style="{StaticResource SmallConnectButton}"
                                                    Content="Connect"
                                                    HorizontalAlignment="Right" VerticalAlignment="Center"
                                                    Command="{Binding DataContext.ConnectToDeviceCommand,
                                                              RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding}">
                                                <Button.Visibility>
                                                    <MultiBinding Converter="{StaticResource StringNeqToVis}">
                                                        <Binding Path="Name"/>
                                                        <Binding Path="DataContext.ConnectedDeviceName"
                                                                 RelativeSource="{RelativeSource AncestorType=Window}"/>
                                                    </MultiBinding>
                                                </Button.Visibility>
                                            </Button>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Disconnect button (only when connected) -->
                        <Button Content="Disconnect" Style="{StaticResource DangerButton}"
                                Command="{Binding DisconnectCommand}" Margin="0,8,0,0"
                                Visibility="{Binding ConnectedDeviceName, Converter={StaticResource NullToCollapsed}}"
                                HorizontalAlignment="Stretch"/>

                    </StackPanel>
                </Border>

                <!-- ═══ MIDI MONITOR ═══ -->
                <Border Style="{StaticResource CardBorder}">
                    <StackPanel>

                        <!-- Header -->
                        <Grid Margin="0,0,0,8">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🎵" FontSize="14" Foreground="{StaticResource AccentAmberBrush}"
                                           Margin="0,0,6,0" VerticalAlignment="Center"/>
                                <TextBlock Text="MIDI Monitor" Style="{StaticResource HeadingText}"/>
                                <TextBlock Style="{StaticResource SecondaryText}"
                                           Foreground="{StaticResource TextMutedBrush}"
                                           Margin="8,0,0,0" VerticalAlignment="Center">
                                    <Run Text="("/>
                                    <Run Text="{Binding MessageCount, Mode=OneWay}"/>
                                    <Run Text=" msgs)"/>
                                </TextBlock>
                            </StackPanel>
                            <Button Content="Clear" Style="{StaticResource SecondaryButton}"
                                    Padding="8,2" HorizontalAlignment="Right"
                                    FontSize="12" BorderThickness="0"
                                    Foreground="{StaticResource AccentAmberBrush}"
                                    Command="{Binding ClearMidiLogCommand}"/>
                        </Grid>

                        <!-- Log area -->
                        <Border Background="#0A0A16" CornerRadius="6" Padding="10" MaxHeight="210">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <ItemsControl ItemsSource="{Binding MidiLog}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock FontFamily="Cascadia Mono, Consolas, Courier New"
                                                       FontSize="12" Margin="0,2">
                                                <Run Text="{Binding DirectionArrow, Mode=OneWay}"
                                                     Foreground="{StaticResource TextMutedBrush}"/>
                                                <Run Text=" "/>
                                                <Run Text="{Binding TypeLabel, Mode=OneWay}"
                                                     FontWeight="SemiBold"
                                                     Foreground="{Binding TypeColorHex, Mode=OneWay,
                                                                  Converter={StaticResource HexColorToBrush}}"/>
                                                <Run Text="{Binding DetailText, Mode=OneWay}"
                                                     Foreground="{StaticResource TextSecondaryBrush}"/>
                                                <Run Text="  "/>
                                                <Run Text="{Binding TimeString, Mode=OneWay}"
                                                     Foreground="{StaticResource TextMutedBrush}"/>
                                            </TextBlock>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                    <ItemsControl.Style>
                                        <Style TargetType="ItemsControl">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding MessageCount}" Value="0">
                                                    <Setter Property="Template">
                                                        <Setter.Value>
                                                            <ControlTemplate>
                                                                <TextBlock Text="No MIDI messages yet..."
                                                                           FontSize="12"
                                                                           Foreground="{StaticResource TextMutedBrush}"
                                                                           Margin="0,2"/>
                                                            </ControlTemplate>
                                                        </Setter.Value>
                                                    </Setter>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </ItemsControl.Style>
                                </ItemsControl>
                            </ScrollViewer>
                        </Border>

                    </StackPanel>
                </Border>

                <!-- ═══ DAW SETUP ═══ -->
                <Border Style="{StaticResource CardBorder}">
                    <StackPanel>

                        <!-- Header -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <Ellipse Width="8" Height="8" Fill="{StaticResource AccentAmberBrush}"
                                     Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <TextBlock Text="DAW Setup" Style="{StaticResource HeadingText}"/>
                        </StackPanel>

                        <!-- Intro -->
                        <TextBlock Style="{StaticResource SecondaryText}" TextWrapping="Wrap"
                                   Margin="0,0,0,8" LineHeight="20">
                            GearBoard MIDI works with any DAW that supports virtual MIDI ports:
                        </TextBlock>

                        <!-- 4 steps -->
                        <TextBlock Style="{StaticResource SecondaryText}" TextWrapping="Wrap"
                                   Margin="0,2" LineHeight="20">1.  Open your DAW MIDI settings</TextBlock>
                        <TextBlock Style="{StaticResource SecondaryText}" TextWrapping="Wrap"
                                   Margin="0,2" LineHeight="20">2.  Find "GearBoard MIDI" in the input port list</TextBlock>
                        <TextBlock Style="{StaticResource SecondaryText}" TextWrapping="Wrap"
                                   Margin="0,2" LineHeight="20">3.  Enable Track input → receive CC, PC &amp; Notes</TextBlock>
                        <TextBlock Style="{StaticResource SecondaryText}" TextWrapping="Wrap"
                                   Margin="0,2,0,12" LineHeight="20">4.  Enable Sync output → send clock to GearBoard</TextBlock>

                        <!-- Divider -->
                        <Border Background="{StaticResource BorderSubtleBrush}" Height="1" Margin="0,0,0,10"/>

                        <!-- Section label -->
                        <TextBlock Text="QUICK GUIDE PER DAW" FontSize="10" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   Margin="0,0,0,12"
                                   Typography.Capitals="AllSmallCaps"/>

                        <!-- DAW rows -->
                        <Grid Margin="0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="•" Style="{StaticResource DawBullet}"/>
                            <TextBlock Grid.Column="1" Text="Ableton Live" Style="{StaticResource DawName}"/>
                            <TextBlock Grid.Column="2" Text="Preferences → MIDI → Track / Sync" Style="{StaticResource DawPath}"/>
                        </Grid>
                        <Grid Margin="0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="•" Style="{StaticResource DawBullet}"/>
                            <TextBlock Grid.Column="1" Text="FL Studio" Style="{StaticResource DawName}"/>
                            <TextBlock Grid.Column="2" Text="Options → MIDI Settings → Input" Style="{StaticResource DawPath}"/>
                        </Grid>
                        <Grid Margin="0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="•" Style="{StaticResource DawBullet}"/>
                            <TextBlock Grid.Column="1" Text="Reaper" Style="{StaticResource DawName}"/>
                            <TextBlock Grid.Column="2" Text="Options → Preferences → Audio/MIDI" Style="{StaticResource DawPath}"/>
                        </Grid>
                        <Grid Margin="0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="•" Style="{StaticResource DawBullet}"/>
                            <TextBlock Grid.Column="1" Text="Pro Tools" Style="{StaticResource DawName}"/>
                            <TextBlock Grid.Column="2" Text="Setup → MIDI Studio → Enable ports" Style="{StaticResource DawPath}"/>
                        </Grid>
                        <Grid Margin="0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="•" Style="{StaticResource DawBullet}"/>
                            <TextBlock Grid.Column="1" Text="Studio One" Style="{StaticResource DawName}"/>
                            <TextBlock Grid.Column="2" Text="Options → External Devices → New device" Style="{StaticResource DawPath}"/>
                        </Grid>
                        <Grid Margin="0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="•" Style="{StaticResource DawBullet}"/>
                            <TextBlock Grid.Column="1" Text="Cubase / Nuendo" Style="{StaticResource DawName}"/>
                            <TextBlock Grid.Column="2" Text="Studio → Studio Setup → MIDI Port Setup" Style="{StaticResource DawPath}"/>
                        </Grid>

                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- ═══ FOOTER ═══ -->
        <Border Grid.Row="2" Background="{StaticResource BgSurfaceBrush}"
                BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="0,1,0,0"
                Padding="16,8">
            <Grid>
                <!-- BPM display (shown when clock detected) -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center"
                            Visibility="{Binding DetectedBpm, Converter={StaticResource NonZeroToVisible}}">
                    <TextBlock Text="♩ " Foreground="{StaticResource AccentAmberBrush}" FontSize="13"/>
                    <TextBlock Foreground="{StaticResource TextSecondaryBrush}" FontSize="12">
                        <Run Text="{Binding DetectedBpm, StringFormat='{}{0:F1}', Mode=OneWay}"/>
                        <Run Text=" BPM"/>
                    </TextBlock>
                </StackPanel>

                <!-- Settings button -->
                <Button Content="⚙ Settings" HorizontalAlignment="Right"
                        Background="Transparent" BorderThickness="0"
                        Foreground="{StaticResource TextSecondaryBrush}"
                        FontSize="12" Padding="8,4"
                        Click="OnSettingsClick">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Cursor" Value="Hand"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Foreground" Value="{StaticResource AccentAmberBrush}"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>
        </Border>

    </Grid>

    <Window.Style>
        <Style TargetType="Window">
            <Setter Property="FontFamily" Value="Segoe UI"/>
        </Style>
    </Window.Style>
</Window>
